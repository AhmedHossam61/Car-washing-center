# Database
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://carwash_user:your_secure_password@localhost:5432/carwash

# Camera configuration (JSON array)
# role: "entry" | "exit" | "both"
# Single camera: entry+exit are inferred through plate presence timeout.
CAMERAS_JSON=[{"id":1,"name":"Wash Bay","rtsp_url":"rtsp://192.168.1.10:554/stream1","role":"both"}]

# AI thresholds
PLATE_CONFIDENCE=0.4
OCR_CONFIDENCE=0.4
# PP-OCRv5 runs on CPU in the current integrated Windows pipeline.
OCR_USE_GPU=false
# OCR engine: paddle | easyocr
OCR_BACKEND=paddle
# Fallback when primary returns nothing. Set to same as OCR_BACKEND to disable fallback.
OCR_FALLBACK=paddle
# PaddleOCR 3.x recognizer used on detected plate crops.
PADDLE_TEXT_RECOGNITION_MODEL_NAME=PP-OCRv5_mobile_rec
DUPLICATE_GUARD_SECONDS=30
PROCESS_EVERY_N_FRAMES=30
AI_WORKER_COUNT=1
# Plate must appear this many sampled frames before being recorded.
MIN_CONFIRMATION_HITS=2
# Max edit distance between digit strings grouped as the same plate.
CONFIRMATION_FUZZY_THRESHOLD=1
# Live camera timeout is in minutes. Offline recorded-video timeout is in seconds.
PRESENCE_TIMEOUT_MINUTES=1
VIDEO_ABSENCE_TIMEOUT_SECONDS=40
YOLO_PLATE_WEIGHTS=./models/license-plate-finetune-v1s.pt
# 1920 for 4K cameras (3840x2160), 1280 for 1080p, 640 for old/low-res cameras
YOLO_IMGSZ=1600
# Crop preprocessing before OCR.
# options: current_pipeline, up2_clahe, up2_sharp, up3_clahe, up3_sharp, up2_adaptive, up3_adaptive, ocr_lab
PREPROCESS_VARIANT=ocr_lab
MAX_FRAMES=3000

# Storage
SNAPSHOT_DIR=./snapshots
REPORT_DIR=./reports

# Google Sheets output
GOOGLE_SHEETS_ENABLED=false
GOOGLE_APPS_SCRIPT_URL=your_apps_script_web_app_url
GOOGLE_APPS_SCRIPT_TOKEN=your_shared_token

# API
API_KEY=your_api_key_here
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/carwash.log
